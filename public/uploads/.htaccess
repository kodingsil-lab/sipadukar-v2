Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow only explicit public asset folders.
    RewriteRule ^(settings|lembaga-akreditasi)/ - [L,NC]
    RewriteRule ^index\.html$ - [L,NC]

    # Block all other direct access under /public/uploads.
    RewriteRule ^ - [F,L]
</IfModule>

<IfModule !mod_rewrite.c>
    Require all denied
</IfModule>

<FilesMatch "(?i)\.(php|phtml|phar|pl|py|jsp|asp|aspx|cgi|sh|exe|bat|cmd|com|msi)$">
    Require all denied
</FilesMatch>
