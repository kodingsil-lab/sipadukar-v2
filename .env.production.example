# SIPADUKAR v2 - Production Environment Template
# Copy this file to /home/u541589701/domains/sipadukar.unisap.ac.id/shared/.env
# lalu sesuaikan nilainya sebelum deploy pertama.

# --------------------------------------------------------------------
# ENVIRONMENT
# --------------------------------------------------------------------
CI_ENVIRONMENT = production

# --------------------------------------------------------------------
# APP
# --------------------------------------------------------------------
# Gunakan domain produksi final dengan trailing slash.
app.baseURL = 'https://sipadukar.unisap.ac.id/'

# Force HTTPS globally for all requests.
app.forceGlobalSecureRequests = true

# Pastikan URL index hilang di production.
app.indexPage = ''

# Nonaktifkan toolbar debug di production.
app.CSPEnabled = false

# --------------------------------------------------------------------
# DATABASE
# --------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = isi_nama_database
database.default.username = isi_user_database
database.default.password = isi_password_database
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.DBDebug = false
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci
database.default.strictOn = false

# --------------------------------------------------------------------
# SESSION
# --------------------------------------------------------------------
# Keep 1 hour session lifetime for a good balance between security and usability.
session.expiration = 3600

# Gunakan file session bawaan. Jika hosting menyediakan path khusus, sesuaikan.
# session.driver = 'CodeIgniter\\Session\\Handlers\\FileHandler'
# session.savePath = '/home/u541589701/tmp'

# Rotate session ID every 5 minutes.
session.timeToUpdate = 300

# Destroy old session ID data after regeneration.
session.regenerateDestroy = true

# Keep false for campus usability (users may switch IP/network frequently).
session.matchIP = false

# --------------------------------------------------------------------
# COOKIE
# --------------------------------------------------------------------
# Enforce secure cookie attributes in production.
cookie.secure = true
cookie.httponly = true
cookie.samesite = 'Lax'

# --------------------------------------------------------------------
# LOGGER
# --------------------------------------------------------------------
logger.threshold = 4

# --------------------------------------------------------------------
# CACHE
# --------------------------------------------------------------------
# Jika ingin eksplisit memakai file cache bawaan, aktifkan ini.
# cache.handler = file

# --------------------------------------------------------------------
# SECURITY (CSRF)
# --------------------------------------------------------------------
security.csrfProtection = 'cookie'
security.regenerate = true
security.redirect = true

# --------------------------------------------------------------------
# OPTIONAL: Proxy (if behind load balancer / reverse proxy)
# --------------------------------------------------------------------
# Example only - adjust to your infrastructure.
# app.proxyIPs = '10.0.1.200'
